FOODNOTE_IMAGE=foodnote:0.22.179
# Chemins de montage Docker Compose.
# Par défaut : projet courant + ./database.
# Exemple Dockge/Proxmox : /mnt/Docker/data/nginx
FOODNOTE_APP_DIR=.
FOODNOTE_DATA_DIR=./database

PORT=3000
DATA_DIR=/data
PUBLIC_DIR=/app/public
FOODNOTE_DEFAULT_USER=default
GROQ_API_KEY=
# Par défaut, pour GitHub/self-host propre, la clé IA doit venir de Docker.
# Mets 1 seulement si tu veux autoriser la sauvegarde de la clé Groq dans SQLite depuis l’interface.
FOODNOTE_ALLOW_UI_SECRET_STORAGE=0
FOODNOTE_APP_LABEL=FoodNote beta 0.22.179
FOODNOTE_TZ=Europe/Paris
FOODNOTE_MQTT_ENABLED=0
FOODNOTE_MQTT_URL=mqtt://192.168.1.10:1883
FOODNOTE_MQTT_USERNAME=
FOODNOTE_MQTT_PASSWORD=
FOODNOTE_MQTT_BASE_TOPIC=foodnote
FOODNOTE_MQTT_DISCOVERY=1
FOODNOTE_MQTT_DISCOVERY_PREFIX=homeassistant
FOODNOTE_MQTT_RETAIN=1

# CIQUAL ANSES : avec Dockge/Proxmox, préfère l'import manuel en --network=host.
# Mets 1 seulement si le réseau HTTPS fonctionne bien dans le conteneur.
FOODNOTE_CIQUAL_AUTO_DOWNLOAD=0
FOODNOTE_CIQUAL_AUTO_IMPORT=1
